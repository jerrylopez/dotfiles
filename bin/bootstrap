#!/usr/bin/env bash

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "${BASEDIR}"

if test ! $(which brew)
then
    ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
fi

brew bundle --file="${BASEDIR}/config/homebrew/Brewfile"

"${BASEDIR}/bin/install"

"${BASEDIR}/bin/defaults"